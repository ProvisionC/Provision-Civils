{
  "expo": {
    "name": "Provision Civils",
    "slug": "provision-civils",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/a6093da0-719f-4eee-86e4-a87d0059c219",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "provision-civils",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Provision Civils to use the microphone for voice-to-text on daily reports.",
        "NSSpeechRecognitionUsageDescription": "Allow Provision Civils to recognise speech for Afrikaans voice notes."
      }
    },
    "android": {
      "package": "com.provisioncivils.app",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1565C0"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
       
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Provision Civils to record GPS location for daily reports."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Provision Civils to access your photo library to attach site photos.",
          "cameraPermission": "Allow Provision Civils to use your camera to capture site photos."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Provision Civils to use the microphone for voice-to-text on daily reports.",
          "speechRecognitionPermission": "Allow Provision Civils to recognise speech for Afrikaans voice notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a6093da0-719f-4eee-86e4-a87d0059c219"
      }
    },
    "owner": "marconagel"
  }
}
